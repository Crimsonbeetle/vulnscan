{"created_at": 1775028847.564814, "status_code": 200, "payload": [{"ghsa_id": "GHSA-r9jw-mwhq-wp62", "cve_id": "CVE-2017-11424", "url": "https://api.github.com/advisories/GHSA-r9jw-mwhq-wp62", "html_url": "https://github.com/advisories/GHSA-r9jw-mwhq-wp62", "summary": "PyJWT vulnerable to key confusion attacks", "description": "In PyJWT 1.5.0 and below the `invalid_strings` check in `HMACAlgorithm.prepare_key` does not account for all PEM encoded public keys. Specifically, the PKCS1 PEM encoded format would be allowed because it is prefaced with the string `-----BEGIN RSA PUBLIC KEY-----` which is not accounted for. This enables symmetric/asymmetric key confusion attacks against users using the PKCS1 PEM encoded public keys, which would allow an attacker to craft JWTs from scratch.", "type": "reviewed", "severity": "high", "repository_advisory_url": null, "source_code_location": "https://github.com/jpadilla/pyjwt", "identifiers": [{"value": "GHSA-r9jw-mwhq-wp62", "type": "GHSA"}, {"value": "CVE-2017-11424", "type": "CVE"}], "references": ["https://nvd.nist.gov/vuln/detail/CVE-2017-11424", "https://github.com/jpadilla/pyjwt/pull/277", "http://www.debian.org/security/2017/dsa-3979", "https://github.com/pypa/advisory-database/tree/main/vulns/pyjwt/PYSEC-2017-24.yaml", "https://github.com/advisories/GHSA-r9jw-mwhq-wp62"], "published_at": "2022-05-13T01:42:19Z", "updated_at": "2024-10-15T16:34:42Z", "github_reviewed_at": "2022-09-12T14:50:37Z", "nvd_published_at": "2017-08-24T16:29:00Z", "withdrawn_at": null, "vulnerabilities": [{"package": {"ecosystem": "pip", "name": "pyjwt"}, "vulnerable_version_range": "< 1.5.1", "first_patched_version": "1.5.1", "vulnerable_functions": []}], "cvss_severities": {"cvss_v3": {"vector_string": "CVSS:3.0/AV:N/AC:L/PR:N/UI:N/S:U/C:N/I:H/A:N", "score": 7.5}, "cvss_v4": {"vector_string": null, "score": 0.0}}, "cwes": [], "credits": [{"user": {"login": "jhutchings1", "id": 12853539, "node_id": "MDQ6VXNlcjEyODUzNTM5", "avatar_url": "https://a